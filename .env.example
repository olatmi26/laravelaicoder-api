APP_NAME=LaravelAICoder
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api.up.railway.app
FRONTEND_URL=https://laravelaicoder.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (Railway injects these automatically) ──
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ── Redis (Railway injects these automatically) ──
REDIS_URL=${REDIS_URL}
REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT}
REDIS_PASSWORD=${REDISPASSWORD}

# ── Queue & Cache ──
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# ── AI Providers (platform default keys) ──
DEFAULT_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=sk-proj-
OPENAI_MODEL=gpt-4o

# ── Flutterwave ──
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-
FLUTTERWAVE_SECRET_KEY=FLWSECK-
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-hash

# ── Storage (S3 for file uploads) ──
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laravelaicoder-uploads
AWS_URL=

# ── Email ──
MAIL_MAILER=resend
RESEND_API_KEY=re_

# ── Sanctum ──
SANCTUM_STATEFUL_DOMAINS=laravelaicoder.vercel.app,localhost:3000
